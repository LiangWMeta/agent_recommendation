# Data (local files are large/symlinked — track registry only)
data/local/
!data/datasets.md

# Generated user contexts (keep README, ignore per-request folders)
user/*/
!user/README.md

# Generated ads pool context (keep README + refresh script, ignore generated md)
ads_pool/pool_overview.md
ads_pool/catalog.md
ads_pool/semantic_clusters.md

